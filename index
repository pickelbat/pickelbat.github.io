<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DJ Landing Page</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <main class="container">
    <section class="hero">
      <h1>DJ NAME</h1>
      <p>Live in Bogotá, Colombia</p>
    </section>

    <section class="video-section">
      <h2>Highlight Reel</h2>
      <div class="video-wrap">
        <video controls playsinline poster="">
          <source src="highlight-reel.mp4" type="video/mp4" />
          Your browser does not support the video tag.
        </video>
      </div>
    </section>

    <section class="buttons">
      <a class="btn" href="https://open.spotify.com/" target="_blank" rel="noopener noreferrer">
        Listen on Spotify
      </a>

      <a class="btn secondary" href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer">
        Follow on Instagram
      </a>
    </section>
  </main>
</body>
</html>
