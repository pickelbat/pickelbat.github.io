<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DJ Landing</title>

<style>

body {
  margin:0;
  font-family: Arial;
  color:white;
  text-align:center;
  background:black;
}

/* VIDEO BACKGROUND */

.video-background {
  position: fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  z-index:-1;
  overflow:hidden;
}

.video-background iframe {
  width:100vw;
  height:100vh;
  pointer-events:none;
}

/* CONTENT */

.content {
  position:relative;
  z-index:1;
  padding-top:40vh;
}

h1 {
  font-size:48px;
}

button {
  padding:16px 28px;
  font-size:18px;
  background:#1DB954;
  border:none;
  border-radius:8px;
  color:white;
  cursor:pointer;
}

</style>
</head>

<body>

<div class="video-background">
<iframe
src="https://www.youtube.com/embed/6U_Adjz_Ma4?autoplay=1&mute=1&controls=0&loop=1&playlist=6U_Adjz_Ma4"
frameborder="0"
allow="autoplay; encrypted-media"
allowfullscreen>
</iframe>
</div>

<div class="content">

<h1>DJ NAME</h1>

<br>

<a href="https://open.spotify.com/" target="_blank">
<button>Listen on Spotify</button>
</a>

</div>

</body>
</html>
